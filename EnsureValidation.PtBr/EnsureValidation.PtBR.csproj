<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net6.0;net7.0;net8.0;net9.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>12</LangVersion>

    <PackageId>EnsureValidation.PtBR</PackageId>
    <Version>1.0.0</Version>
    <Authors>Intsys</Authors>
    <Description>Brazilian Portuguese (pt-BR) localization and CPF/CNPJ validation extensions for EnsureValidation.</Description>
    <PackageTags>validation;pt-BR;cpf;cnpj;brazil;</PackageTags>

    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="EnsureValidation" Version="1.0.0" />
  </ItemGroup>

</Project>
